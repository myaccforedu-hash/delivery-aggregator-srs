{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "definitions": {

    "CreateOrderRequest": {
      "type": "object",
      "required": ["address", "items"],
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "maxLength": 255
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 100
          }
        }
      }
    },

    "UpdateOrderRequest": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "deliveryProviderId": {
          "type": "string",
          "maxLength": 50
        }
      }
    },

    "OrderAsyncResponse": {
      "type": "object",
      "required": ["orderId", "status", "_links"],
      "additionalProperties": false,
      "properties": {
        "orderId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["CREATED", "PROCESSING"]
        },
        "_links": {
          "$ref": "#/definitions/Links"
        }
      }
    },

    "Order": {
      "type": "object",
      "properties": {
        "orderId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "CREATED",
            "PROCESSING",
            "DELIVERY_SELECTED",
            "PAID",
            "PAYMENT_FAILED",
            "CANCELLED"
          ],
          "default": "CREATED"
        },
        "deliveryProviderId": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 100
          }
        },
        "_links": {
          "$ref": "#/definitions/Links"
        }
      }
    },

    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "integer"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "string"
        }
      }
    },

    "Links": {
      "type": "object",
      "required": ["href", "method"],
      "properties": {
        "href": {
          "type": "string"
        },
        "method": {
          "type": "string",
          "enum": ["GET", "PATCH", "DELETE"]
        },
        "self": {
          "$ref": "#/definitions/Link"
        },
        "update": {
          "$ref": "#/definitions/Link"
        },
        "cancel": {
          "$ref": "#/definitions/Link"
        },
        "status": {
          "$ref": "#/definitions/Link"
        }
      }
    },

    "Link": {
      "type": "object",
      "properties": {
        "href": {
          "type": "string"
        },
        "method": {
          "type": "string",
          "enum": ["GET", "PATCH", "DELETE"]
        }
      }
    }

  }
}